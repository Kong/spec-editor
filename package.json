{
  "author": {
    "name": "Kong Inc.",
    "url": "https://konghq.com/"
  },
  "config": {
    "commitizen": {
      "jiraAppend": "]",
      "jiraLocation": "post-description",
      "jiraOptional": true,
      "jiraPrepend": "[",
      "path": "./node_modules/@digitalroute/cz-conventional-changelog-for-jira",
      "skipScope": false
    }
  },
  "dependencies": {
    "@kong-ui-public/split-pane": "^0.3.10",
    "@kong/icons": "^1.48.0",
    "@kong/kongponents": "^9.52.9",
    "@kong/spec-renderer": "^1.107.5",
    "@stoplight/spectral-core": "^1.21.0",
    "@stoplight/spectral-ruleset-bundler": "^1.6.3",
    "@vueuse/core": "^14.2.1",
    "vue": "^3.5.31"
  },
  "description": "Live editor for Kong's open-source spec renderer",
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@digitalroute/cz-conventional-changelog-for-jira": "^8.0.1",
    "@evilmartians/lefthook": "^2.1.4",
    "@kong/design-tokens": "^1.20.1",
    "@kong/eslint-config-kong-ui": "1.6.2",
    "@shikijs/monaco": "^4.0.2",
    "@stoplight/types": "^14.1.1",
    "@stylistic/stylelint-plugin": "^5.1.0",
    "@types/node": "^25.5.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitest/ui": "^4.1.2",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.9.1",
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^9.39.2",
    "eslint-plugin-vue": "^10.8.0",
    "happy-dom": "^20.8.9",
    "monaco-editor": "^0.55.1",
    "npm-run-all2": "^8.0.4",
    "sass": "^1.98.0",
    "sass-embedded": "^1.98.0",
    "shiki": "^4.0.2",
    "stylelint": "^17.6.0",
    "stylelint-config-html": "^1.1.0",
    "stylelint-config-recommended-scss": "^17.0.0",
    "stylelint-config-recommended-vue": "^1.6.1",
    "stylelint-order": "^8.1.1",
    "typescript": "^5.9.3",
    "vite": "^8.0.3",
    "vite-plugin-vue-devtools": "^8.1.1",
    "vitest": "^4.1.2",
    "vue-tsc": "^3.2.6"
  },
  "name": "@kong/spec-editor",
  "private": true,
  "scripts": {
    "build": "run-p typecheck \"build-only {@}\" --",
    "build-only": "vite build",
    "commit": "cz",
    "dev": "vite",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "preview": "vite preview",
    "stylelint": "stylelint --allow-empty-input './src/**/*.{css,scss,vue}'",
    "stylelint:fix": "stylelint --allow-empty-input './src/**/*.{css,scss,sass,vue}' --fix",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "typecheck": "vue-tsc -p './tsconfig.json' --noEmit"
  },
  "type": "module",
  "version": "0.0.0",
  "volta": {
    "node": "24.13.0",
    "pnpm": "10.28.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@evilmartians/lefthook",
      "@parcel/watcher",
      "esbuild",
      "vue-demi"
    ],
    "overrides": {
      "@babel/runtime@<7.26.10": ">=7.26.10",
      "@babel/helpers@<7.26.10": ">=7.26.10",
      "brace-expansion@<1.1.13": ">=1.1.13",
      "brace-expansion@>=2.0.0 <2.0.3": ">=2.0.3",
      "tmp@<=0.2.3": ">=0.2.4",
      "form-data@>=4.0.0 <4.0.4": ">=4.0.4",
      "lodash@<=4.17.23": ">=4.18.0",
      "lodash-es@<=4.17.23": ">=4.18.0",
      "mdast-util-to-hast@>=13.0.0 <13.2.1": ">=13.2.1",
      "minimatch@<3.1.4": ">=3.1.4",
      "minimatch@>=9.0.0 <9.0.7": ">=9.0.7",
      "rollup@<2.80.0": ">=2.80.0",
      "flatted@<=3.4.1": ">=3.4.2",
      "dompurify@<3.3.2": ">=3.3.2",
      "picomatch@<2.3.2": ">=2.3.2",
      "picomatch@>=4.0.0 <4.0.4": ">=4.0.4"
    }
  }
}
